<!DOCTYPE html>
<html>
  <body style="font-family: system-ui; color: #1a1a1a; background:#f7f7fb; padding:24px;">
    <table style="background:#ffffff; max-width:560px; margin:auto; border-radius:8px; overflow:hidden;">
      <tr>
        <td style="padding:24px;">
          <h2 style="margin:0 0 8px; color:#002395;">Good news from {{siteName}}!</h2>
          <p style="margin:0 0 16px; line-height:1.5;">
            <strong>{{productName}}</strong> is back in stock. We saved your spot — head over and grab it before it sells out again.
          </p>
          <p style="margin: 16px 0;">
            <a href="{{productUrl}}" style="background:#002395; color:#fff; text-decoration:none; padding:10px 18px; border-radius:6px; display:inline-block;">View product</a>
          </p>
          <p style="font-size:12px; color:#888; margin-top:24px;">
            You receive this email because you asked us to notify you when this product was restocked.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>

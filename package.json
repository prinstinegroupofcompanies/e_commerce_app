{
  "name": "shoplib",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "dev:clean": "npm run clean && next dev",
    "dev:stable": "bash -lc 'ulimit -n 65536 2>/dev/null || ulimit -n 10240 2>/dev/null || true; export WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true; exec next dev'",
    "dev": "next dev",
    "postinstall": "node scripts/prepare-prisma.js && prisma generate",
    "build": "next build",
    "build:render": "node scripts/prepare-prisma.js && prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "vapid:keys": "node scripts/generate-vapid-keys.js",
    "setup:integrations": "node scripts/setup-integrations.js",
    "users:production": "node scripts/ensure-production-users.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@paypal/paypal-server-sdk": "^2.3.0",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@stripe/react-stripe-js": "^3.6.0",
    "@stripe/stripe-js": "^5.10.0",
    "@tanstack/react-query": "^5.66.0",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "handlebars": "^4.7.9",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.469.0",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.25",
    "next-pwa": "^5.6.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.15.0",
    "sharp": "^0.33.5",
    "sonner": "^1.7.1",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },

# Database
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Render PostgreSQL — use External Database URL on Vercel):
# DATABASE_URL="postgresql://user:pass@host:5432/markayhall"

# NextAuth — must match the public site URL (Vercel domain in production)
NEXTAUTH_SECRET="generate-a-long-random-string"
AUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Markay Hall"

# Vercel only: Render API URL for upload tokens + /uploads proxy (no trailing slash)
# RENDER_BACKEND_URL="https://markay-hall-api.onrender.com"
# Optional: explicit public URL for uploaded images (defaults to RENDER_BACKEND_URL)
# NEXT_PUBLIC_UPLOAD_BASE_URL="https://markay-hall-api.onrender.com"
# Upload token signing — defaults to CRON_SECRET when unset (must match on Vercel + Render)
# UPLOAD_INTERNAL_SECRET="same-as-cron-secret"

# Render cron jobs only: public URL of markay-hall-api service
# MARKAY_API_URL="https://markay-hall-api.onrender.com"

# Customer signup: set to "false" to skip email verification (dev only)
REQUIRE_EMAIL_VERIFICATION="true"

# Cron jobs — call with Authorization: Bearer CRON_SECRET or ?secret=
CRON_SECRET="generate-another-random-string"
# Weekly shop analytics email (optional; defaults to first active admin if unset)
ANALYTICS_REPORT_EMAIL=

# SMTP (optional — emails skip when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Markay Hall <noreply@example.com>"

# Shop assistant (optional — uses smart rules when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# SMS (optional — Twilio or generic webhook)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Or POST { to, body } JSON to your SMS gateway:
SMS_WEBHOOK_URL=

# Web push (run: npm run vapid:keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@markayhall.local"

# Mobile money — Flutterwave (optional; one API for Orange/MTN MoMo)
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Manual mobile money confirm (when Flutterwave is not used)
MOBILE_MONEY_WEBHOOK_SECRET=
